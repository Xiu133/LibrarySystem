@model Library.Models.IncomeRecord
@{
    ViewData["Title"] = "收款表單";
    var userConfirmed = ViewBag.UserConfirmed as bool? ?? false;
    var userName = ViewBag.UserName as string ?? "";
    var error = ViewBag.Error as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/income-income.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">收款表單</div>
        <div class="page-subtitle">記錄收款資料</div>
    </div>
    <a asp-action="Index" class="btn btn-outline">← 返回</a>
</div>

<div class="income-layout">
    <div class="step-card">
        <div class="step-title">Step 1 — 確認會員</div>
        <form asp-action="Income" method="get">
            <div class="form-group">
                <label class="form-label">會員帳號</label>
                <div style="display:flex;gap:8px">
                    <input type="text" name="userName" value="@userName" class="form-control" placeholder="請輸入會員帳號" required />
                    <button type="submit" class="btn btn-primary" style="white-space:nowrap">確認</button>
                </div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div style="color:var(--danger);font-size:0.85rem;margin-top:6px">@error</div>
                }
            </div>
        </form>
    </div>

    @if (userConfirmed)
    {
        <div class="step-card">
            <div class="step-title">Step 2 — 收款資料</div>
            <div class="user-confirmed-box">
                <div class="user-confirmed-icon">✅</div>
                <div class="user-confirmed-name">@userName</div>
            </div>
            <form asp-action="RecordPayment" asp-controller="Income" method="post">
                <input type="hidden" name="userName" value="@userName" />
                <div class="form-group">
                    <label class="form-label">收款事由</label>
                    <select name="Reason" class="form-control" required>
                        <option value="">請選擇</option>
                        <option>損壞賠償</option>
                        <option>遺失賠償</option>
                        <option>逾期罰款</option>
                        <option>其他</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">金額（NT$）</label>
                    <input type="number" name="Money" class="form-control" placeholder="0" min="1" step="0.01" required />
                </div>
                <button type="submit" class="btn btn-accent w-full">確認收款</button>
            </form>
        </div>
    }
</div>

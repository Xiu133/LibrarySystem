@{
    ViewData["Title"] = "收款作業";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/income-income.css" asp-append-version="true" />
}

<div id="app">
    <div class="page-header">
        <div>
            <div class="page-title">收款作業</div>
            <div class="page-subtitle">確認會員並記錄收款</div>
        </div>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline">← 返回後台</a>
    </div>

    <div class="income-layout">
        <div class="step-card">
            <div class="step-title">Step 1 — 確認會員</div>
            <div class="form-group">
                <label class="form-label">會員帳號</label>
                <div style="display:flex;gap:8px">
                    <input type="text" v-model="userName" class="form-control"
                           placeholder="請輸入會員帳號" @@keyup.enter="confirmUser" />
                    <button type="button" class="btn btn-primary" style="white-space:nowrap"
                            @@click="confirmUser" :disabled="loading">確認</button>
                </div>
                <div v-if="error" style="color:var(--danger);font-size:0.85rem;margin-top:6px">{{ error }}</div>
            </div>
        </div>

        <div class="step-card" v-show="confirmed">
            <div class="step-title">Step 2 — 收款資料</div>
            <div class="user-confirmed-box">
                <div class="user-confirmed-icon">✅</div>
                <div class="user-confirmed-name">{{ userName }}</div>
            </div>
            <form asp-action="RecordPayment" asp-controller="Income" method="post">
                <input type="hidden" name="userName" :value="userName" />
                <div class="form-group">
                    <label class="form-label">收款事由</label>
                    <select name="Reason" class="form-control" required>
                        <option value="">請選擇</option>
                        <option>損壞賠償</option>
                        <option>遺失賠償</option>
                        <option>逾期罰款</option>
                        <option>其他</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">金額（NT$）</label>
                    <input type="number" name="Money" class="form-control" placeholder="0" min="1" step="0.01" required />
                </div>
                <button type="submit" class="btn btn-accent w-full">確認收款</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/views/income-index.js" asp-append-version="true"></script>
}

@using Library.Models
@model List<Notify>
@{
    ViewData["Title"] = "通知中心";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/notify-index.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">通知中心</div>
        <div class="page-subtitle">您的借閱相關通知</div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">🔔</div>
                <div class="empty-state-text">目前沒有通知</div>
                <div class="empty-state-sub">您的借閱通知將顯示於此</div>
            </div>
        }
        else
        {
            @foreach (var n in Model)
            {
                <div class="notify-item">
                    <div class="notify-dot @(n.IsRead ? "read" : "")"></div>
                    <div class="notify-content">
                        <div class="notify-message">@n.Message</div>
                        <div class="notify-date">@n.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                </div>
            }
        }
    </div>
</div>

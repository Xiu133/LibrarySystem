@{
    ViewData["Title"] = "預約書籍";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/reserve-index.css" asp-append-version="true" />
}

<div id="app">
    <div class="page-header">
        <div>
            <div class="page-title">預約書籍</div>
            <div class="page-subtitle">預約目前無法借閱的書籍，到貨時通知您</div>
        </div>
    </div>

    <div class="reserve-layout">
        <div>
            <div class="search-bar">
                <input v-model="query" class="search-input" placeholder="搜尋書名或作者..." @@input="search" />
                <button class="btn btn-outline" @@click="loadAll">全部</button>
            </div>
            <div v-if="loading" class="empty-state">
                <div class="empty-state-icon">⏳</div>
                <div class="empty-state-text">載入中...</div>
            </div>
            <div v-else-if="books.length === 0" class="empty-state">
                <div class="empty-state-icon">📚</div>
                <div class="empty-state-text">找不到相關書籍</div>
            </div>
            <div v-else class="book-grid">
                <div v-for="book in books" :key="book.id"
                     class="book-item"
                     :class="{selected: isSelected(book.id)}"
                     @@click="toggleSelect(book)">
                    <img :src="book.imageFileName" :alt="book.title" onerror="this.style.display='none'" style="background:var(--surface);width:100%;height:160px;object-fit:cover" />
                    <div class="book-item-info">
                        <div class="book-item-title">{{ book.title }}</div>
                        <div class="book-item-author">{{ book.author }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="cart-panel">
            <div class="cart-title">📋 預約清單 <span class="badge badge-info">{{ selected.length }}</span></div>
            <div v-if="selected.length === 0" class="cart-empty">
                <div style="font-size:2rem;margin-bottom:8px">🔖</div>
                <div>點擊書籍加入預約清單</div>
            </div>
            <div v-else>
                <div v-for="book in selected" :key="book.id" class="cart-item">
                    <span style="font-size:0.85rem;flex:1">{{ book.title }}</span>
                    <button class="remove-btn" @@click="remove(book.id)">✕</button>
                </div>
            </div>
            <div style="margin-top:16px">
                <button class="btn btn-accent w-full" :disabled="selected.length === 0" @@click="confirm">
                    確認預約{{ selected.length > 0 ? ' (' + selected.length + '本)' : '' }}
                </button>
            </div>
            <div v-if="resultMsg" class="alert mt-2" :class="resultSuccess ? 'alert-success' : 'alert-danger'">{{ resultMsg }}</div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/views/reserve-index.js" asp-append-version="true"></script>
}

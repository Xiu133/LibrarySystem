@model List<Library.Models.User>
@{
    ViewData["Title"] = "帳號管理";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/account-manage.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">帳號管理</div>
        <div class="page-subtitle">管理用戶帳號權限</div>
    </div>
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline">← 返回後台</a>
</div>

<div class="card">
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>帳號</th>
                    <th>角色</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Where(u => u.Role != "Admin"))
                {
                    <tr>
                        <td class="fw-medium">@user.UserName</td>
                        <td><span class="role-badge-user">會員</span></td>
                        <td>
                            <form asp-controller="Account" asp-action="PromoteToAdmin" method="post">
                                <input type="hidden" name="userid" value="@user.Id" />
                                <button type="submit" class="btn btn-primary btn-xs">升級為管理員</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

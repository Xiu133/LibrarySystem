@{
    ViewData["Title"] = "註冊";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/account-register.css" asp-append-version="true" />
}

<div class="register-card">
    <div class="register-title">📚 建立帳號</div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="Register" method="post">
        <div class="form-group">
            <label class="form-label">帳號</label>
            <input type="text" name="username" class="form-control" placeholder="請輸入帳號" required autocomplete="username" />
        </div>
        <div class="form-group">
            <label class="form-label">密碼</label>
            <input type="password" name="password" class="form-control" placeholder="至少 4 個字元" required autocomplete="new-password" />
        </div>
        <button type="submit" class="btn btn-primary w-full" style="margin-top:8px;padding:12px">建立帳號</button>
    </form>

    <div style="text-align:center;margin-top:20px;font-size:0.85rem;color:var(--text-muted)">
        已有帳號？<a asp-action="Login" style="color:var(--accent);text-decoration:none">立即登入</a>
    </div>
</div>

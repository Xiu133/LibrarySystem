@using Library.ViewModel
@model List<BookViewModel>
@{
    ViewData["Title"] = "搜尋結果";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/book-search-result.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">搜尋結果</div>
        <div class="result-count">找到 @Model.Count 筆結果</div>
    </div>
    <a asp-action="Index" class="btn btn-outline">← 返回書籍列表</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">🔍</div>
        <div class="empty-state-text">找不到相關書籍</div>
        <div class="empty-state-sub">請嘗試其他關鍵字</div>
    </div>
}
else
{
    <div class="card">
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>書名</th>
                        <th>作者</th>
                        <th>出版年份</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Detail" asp-route-id="@book.Id" style="color:var(--primary);font-weight:500;text-decoration:none">
                                    @book.Title
                                </a>
                            </td>
                            <td class="text-muted">@book.Author</td>
                            <td class="text-muted">@book.PublishedYear</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@model Library.Models.Book
@{
    ViewData["Title"] = "編輯書籍";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/book-edit.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">編輯書籍</div>
        <div class="page-subtitle">搜尋並更新書籍資料</div>
    </div>
    <a asp-action="Manage" class="btn btn-outline">← 返回</a>
</div>

<div class="form-card">
    <div class="search-section">
        <form method="get" asp-action="Edit">
            <label class="form-label">查詢書名</label>
            <div style="display:flex;gap:8px">
                <input type="text" name="Title" class="form-control" placeholder="輸入書名查詢..." value="@ViewBag.SearchTitle" />
                <button type="submit" class="btn btn-primary">查詢</button>
            </div>
        </form>
    </div>

    @if (Model != null)
    {
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
            <input type="hidden" asp-for="ImageFileName" />

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">書名 *</label>
                    <input asp-for="Title" class="form-control" required />
                </div>
                <div class="form-group">
                    <label class="form-label">作者 *</label>
                    <input asp-for="Author" class="form-control" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">簡介</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">出版年份</label>
                    <input asp-for="PublishedYear" type="number" class="form-control" required />
                </div>
                <div class="form-group">
                    <label class="form-label">數量</label>
                    <input asp-for="Quantity" type="number" class="form-control" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">ISBN</label>
                    <input asp-for="ISBN" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">存放位置</label>
                    <input asp-for="Location" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">更換封面（選填）</label>
                <input type="file" name="ImageFile" class="form-control" accept="image/*" />
            </div>

            <div style="display:flex;gap:8px;margin-top:24px">
                <button type="submit" class="btn btn-primary">更新書籍</button>
                <a asp-action="Manage" class="btn btn-outline">取消</a>
            </div>
        </form>
    }
</div>

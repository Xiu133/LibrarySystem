@model Library.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/book-detail.css" asp-append-version="true" />
}

<div style="margin-bottom:16px">
    <a asp-action="Index" class="btn btn-outline btn-sm">← 返回書籍列表</a>
</div>

<div class="detail-layout">
    <div>
        <img src="@Model.ImageFileName" alt="@Model.Title" class="detail-cover"
             onerror="this.style.background='var(--surface)';this.style.minHeight='360px'" />
    </div>
    <div class="card card-body">
        <div class="detail-title">@Model.Title</div>
        <div class="detail-author">✍️ @Model.Author</div>
        <div class="detail-meta">
            <span class="badge badge-gray">@Model.PublishedYear 年</span>
            @if (Model.Quantity > 0)
            {
                <span class="badge badge-success">庫存 @Model.Quantity 本</span>
            }
            else
            {
                <span class="badge badge-danger">無庫存</span>
            }
            @if (!string.IsNullOrEmpty(Model.ISBN))
            {
                <span class="badge badge-gray">ISBN: @Model.ISBN</span>
            }
            @if (!string.IsNullOrEmpty(Model.Location) && Model.Location != "未分類")
            {
                <span class="badge badge-info">📍 @Model.Location</span>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="detail-description">@Model.Description</div>
        }

        <div style="display:flex;gap:8px;margin-top:24px;flex-wrap:wrap">
            @if (Model.Quantity > 0)
            {
                <a asp-controller="Borrow" asp-action="Index" class="btn btn-accent">借閱此書</a>
            }
            else
            {
                <a asp-controller="Reserve" asp-action="Index" class="btn btn-outline">加入預約</a>
            }
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-Title="@Model.Title" class="btn btn-outline">編輯</a>
            }
        </div>
    </div>
</div>

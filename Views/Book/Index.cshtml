@using Library.Models
@model IEnumerable<Book>
@{
    ViewData["Title"] = "書籍瀏覽";
    var booksJson = System.Text.Json.JsonSerializer.Serialize(Model.Select(b => new {
        id = b.Id, title = b.Title, author = b.Author, imageFileName = b.ImageFileName, quantity = b.Quantity
    }));
    var isAdmin = User.IsInRole("Admin");
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/book-index.css" asp-append-version="true" />
}

<div id="app">
    <div class="page-header">
        <div>
            <div class="page-title">書籍瀏覽</div>
            <div class="page-subtitle">館藏 @Model.Count() 本書籍</div>
        </div>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-accent">+ 新增書籍</a>
        }
    </div>

    <div class="book-search-bar">
        <input v-model="query" class="search-input" placeholder="搜尋書名或作者..." @@input="search" />
        <button class="btn btn-outline" @@click="reset">全部</button>
    </div>

    <div v-if="loading" class="empty-state">
        <div class="empty-state-icon">⏳</div>
        <div class="empty-state-text">搜尋中...</div>
    </div>
    <div v-else-if="books.length === 0" class="empty-state">
        <div class="empty-state-icon">📚</div>
        <div class="empty-state-text">找不到相關書籍</div>
    </div>
    <div v-else class="book-grid">
        <div v-for="book in books" :key="book.id" class="book-card" @@click="openDrawer(book.id)">
            <img :src="book.imageFileName" :alt="book.title"
                 onerror="this.style.background='var(--surface)';this.style.minHeight='220px'"
                 style="width:100%;height:220px;object-fit:cover;display:block" />
            <div class="book-card-body">
                <div class="book-card-title">{{ book.title }}</div>
                <div class="book-card-author">{{ book.author }}</div>
                <div class="book-card-qty" :style="book.quantity > 0 ? 'color:var(--success)' : 'color:var(--danger)'">
                    {{ book.quantity > 0 ? '庫存 ' + book.quantity + ' 本' : '無庫存' }}
                </div>
            </div>
        </div>
    </div>

    <!-- Book Detail Drawer -->
    <div class="drawer-overlay" :class="{open: drawerOpen}" @@click.self="closeDrawer">
        <div class="drawer-panel" :class="{open: drawerOpen}">
            <button class="drawer-close" @@click="closeDrawer">✕</button>
            <div v-if="drawerLoading" class="drawer-loading">
                <div class="empty-state-icon">⏳</div>
                <div>載入中...</div>
            </div>
            <div v-else-if="drawerBook">
                <img :src="drawerBook.imageFileName" :alt="drawerBook.title"
                     class="drawer-cover"
                     onerror="this.style.background='var(--surface)';this.style.minHeight='200px'" />
                <div class="drawer-body">
                    <div class="drawer-title">{{ drawerBook.title }}</div>
                    <div class="drawer-author">✍️ {{ drawerBook.author }}</div>
                    <div class="drawer-meta">
                        <span class="badge badge-gray">{{ drawerBook.publishedYear }} 年</span>
                        <span class="badge" :class="drawerBook.quantity > 0 ? 'badge-success' : 'badge-danger'">
                            {{ drawerBook.quantity > 0 ? '庫存 ' + drawerBook.quantity + ' 本' : '無庫存' }}
                        </span>
                        <span v-if="drawerBook.isbn" class="badge badge-gray">ISBN: {{ drawerBook.isbn }}</span>
                        <span v-if="drawerBook.location && drawerBook.location !== '未分類'" class="badge badge-info">
                            📍 {{ drawerBook.location }}
                        </span>
                    </div>
                    <div v-if="drawerBook.description" class="drawer-desc">{{ drawerBook.description }}</div>
                    <div class="drawer-actions">
                        <a v-if="drawerBook.quantity > 0" href="/Borrow" class="btn btn-accent">借閱此書</a>
                        <a v-else href="/Reserve" class="btn btn-outline">加入預約</a>
                        <a :href="'/Book/Detail/' + drawerBook.id" class="btn btn-outline">完整詳情</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const initialBooks = @Html.Raw(booksJson);
        const isAdmin = @Html.Raw(isAdmin.ToString().ToLower());
    </script>
    <script src="~/js/views/book-index.js" asp-append-version="true"></script>
}

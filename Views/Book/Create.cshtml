@model Library.Models.Book
@{
    ViewData["Title"] = "新增書籍";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/book-create.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">新增書籍</div>
        <div class="page-subtitle">新增館藏書籍資料</div>
    </div>
    <a asp-action="Manage" class="btn btn-outline">← 返回</a>
</div>

<div class="form-card">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">書名 *</label>
                <input asp-for="Title" class="form-control" placeholder="請輸入書名" required />
            </div>
            <div class="form-group">
                <label class="form-label">作者 *</label>
                <input asp-for="Author" class="form-control" placeholder="請輸入作者" required />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">簡介</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="書籍簡介..."></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">出版年份 *</label>
                <input asp-for="PublishedYear" type="number" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">數量 *</label>
                <input asp-for="Quantity" type="number" class="form-control" min="1" required />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">ISBN</label>
                <input asp-for="ISBN" class="form-control" placeholder="ISBN-13" />
            </div>
            <div class="form-group">
                <label class="form-label">存放位置</label>
                <input asp-for="Location" class="form-control" placeholder="書架位置" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">封面圖片 *</label>
            <div class="file-upload" onclick="document.getElementById('imgInput').click()">
                <div style="font-size:1.5rem;margin-bottom:6px">🖼️</div>
                <div style="font-size:0.875rem;color:var(--text-muted)">點擊上傳封面圖片</div>
                <div id="fileName" style="font-size:0.8rem;color:var(--text-muted);margin-top:4px"></div>
            </div>
            <input type="file" id="imgInput" name="ImageFile" accept="image/*" required style="display:none"
                   onchange="document.getElementById('fileName').textContent = this.files[0]?.name || ''" />
        </div>

        <div style="display:flex;gap:8px;margin-top:24px">
            <button type="submit" class="btn btn-accent">新增書籍</button>
            <a asp-action="Manage" class="btn btn-outline">取消</a>
        </div>
    </form>
</div>

@{
    ViewData["Title"] = "借閱紀錄";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/borrow-record-index.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">我的借閱紀錄</div>
        <div class="page-subtitle">查看您的完整借閱歷史</div>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>書名</th>
                    <th>借閱日期</th>
                    <th>歸還日期</th>
                    <th>狀態</th>
                </tr>
            </thead>
            <tbody>
                @foreach (dynamic record in Model)
                {
                    <tr>
                        <td>@record.BookTitle</td>
                        <td>@record.BorrowRecord.BorrowDate.ToString("yyyy-MM-dd")</td>
                        <td>@(record.BorrowRecord.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>
                            @if (record.ReturnDate == null)
                            {
                                <span class="badge badge-info">借閱中</span>
                            }
                            else
                            {
                                <span class="badge badge-success">已歸還</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

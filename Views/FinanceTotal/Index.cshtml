@{
    ViewData["Title"] = "財務分析";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/finance-total-index.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">財務分析</div>
        <div class="page-subtitle">收入來源與支出趨勢</div>
    </div>
    <div class="page-actions">
        <a asp-controller="Income" asp-action="Index" class="btn btn-accent">收款</a>
        <a asp-controller="Expense" asp-action="Index" class="btn btn-outline">費用管理</a>
    </div>
</div>

<div class="finance-charts">
    <div class="chart-card">
        <div class="chart-title">收入來源分析</div>
        <div class="chart-container">
            <canvas id="incomePieChart"></canvas>
        </div>
    </div>
    <div class="chart-card">
        <div class="chart-title">月度支出趨勢（近12個月）</div>
        <div class="chart-container">
            <canvas id="expenseBarChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/views/finance-total-index.js" asp-append-version="true"></script>
}

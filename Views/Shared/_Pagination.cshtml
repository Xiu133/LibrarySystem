@{
    int page = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    string action = ViewBag.PaginationAction != null ? (string)ViewBag.PaginationAction : "Index";
}

@if (totalPages > 1)
{
    <nav aria-label="分頁導覽" class="mt-3">
        <ul class="pagination justify-content-center flex-wrap">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="@action" asp-route-page="@(page - 1)">上一頁</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="@action" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="@action" asp-route-page="@(page + 1)">下一頁</a>
            </li>
        </ul>
    </nav>
}

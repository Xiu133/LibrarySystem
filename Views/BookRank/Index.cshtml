@model List<Library.ViewModel.PopularBookViewModel>
@{
    ViewData["Title"] = "借閱排行";
    var maxCount = Model.Any() ? Model.Max(b => b.BorrowCount) : 1;
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/book-rank-index.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">借閱排行榜</div>
        <div class="page-subtitle">Top @Model.Count 最受歡迎書籍</div>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table class="data-table rank-table">
            <thead>
                <tr>
                    <th style="width:60px">排名</th>
                    <th>書名</th>
                    <th>作者</th>
                    <th>借閱次數</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var book = Model[i];
                    var rankClass = i == 0 ? "rank-gold" : i == 1 ? "rank-silver" : i == 2 ? "rank-bronze" : "";
                    <tr>
                        <td>
                            <span class="rank-num @rankClass">#@(i + 1)</span>
                        </td>
                        <td class="fw-medium">@book.Title</td>
                        <td class="text-muted">@book.Author</td>
                        <td>
                            <div class="rank-bar-wrap">
                                <div class="rank-bar" data-count="@book.BorrowCount" data-max="@maxCount" style="width:0%"></div>
                                <span class="rank-bar-count">@book.BorrowCount 次</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/views/book-rank-index.js" asp-append-version="true"></script>
}
